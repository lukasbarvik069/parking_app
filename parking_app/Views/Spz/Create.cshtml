@using parking_app.ViewModels
@model SpzViewModel;
@{
    ViewData["Title"] = "Create spz page";
}


<div class="card">
    <div class="card-body p-4">
        <h2 class="card-title text-center mb-4">Vytvoření SPZ</h2>

        <form asp-controller="Spz" asp-action="Create" method="post">
            <div asp-validation-summary="All" class="text-danger mb-3 small"></div>
            <div class="mb-4">
                <label asp-for="Name" class="form-label">Název SPZ</label>
                <input asp-for="Name" type="text" class="form-control" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div class="d-grid">
                <button type="submit" class="btn btn-primary btn-lg">Vytvořit</button>
            </div>
        </form>
    </div>
</div>
