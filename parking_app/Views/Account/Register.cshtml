@using parking_app.ViewModels
@model RegisterViewModel

@{
    ViewData["Title"] = "Register page";
}

<div class="card">
    <div class="card-body p-4">
        <h2 class="card-title text-center mb-4">Registrace</h2>

        <form asp-controller="Account" asp-action="Register" method="post">
            <div asp-validation-summary="All" class="text-danger mb-3 small"></div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="FName" class="form-label">Jméno</label>
                    <input asp-for="FName" class="form-control" placeholder="Jan" />
                    <span asp-validation-for="FName" class="text-danger small"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="LName" class="form-label">Příjmení</label>
                    <input asp-for="LName" class="form-control" placeholder="Novák" />
                    <span asp-validation-for="LName" class="text-danger small"></span>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label">Email</label>
                <input asp-for="Email" type="email" class="form-control" placeholder="name@example.com" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label">Heslo</label>
                <input asp-for="Password" type="password" class="form-control" />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="ConfirmPassword" class="form-label">Potvrzení hesla</label>
                <input asp-for="ConfirmPassword" type="password" class="form-control" />
                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
            </div>

            <div class="d-grid">
                <button type="submit" class="btn btn-primary btn-lg">Zaregistrovat se</button>
            </div>
        </form>

        <div class="text-center mt-3">
            <p class="small">Už máte účet? <a asp-action="Login">Přihlaste se</a></p>
        </div>
    </div>
</div>  

