
@model IEnumerable<ParkingPlace>
@{
    ViewData["Title"] = "Parking places";
}

<div class="container mt-4">
    <h2 class="mb-4 text-center">Dostupná parkoviště</h2>

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @foreach (var p in Model)
        {
            var isFull = p.SpzParkingPlaces.Count() >= p.Capacity;

            <div class="col">
                <div class="card h-100 shadow-sm border-0">
                    <div class="card-header bg-primary text-white py-3">
                        <h5 class="card-title mb-0 text-center">@p.Name</h5>
                    </div>

                    <div class="card-body">
                        <div class="mb-3">
                            <h6 class="text-muted small text-uppercase fw-bold">Adresa</h6>
                            <p class="mb-0">
                                @p.Address.Street @p.Address.HouseNumber<br />
                                <span >@p.Address.PostalCode @p.Address.City</span>
                            </p>
                        </div>

                        <hr class="text-muted opacity-25" />

                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="text-muted small text-uppercase fw-bold">Cena</h6>
                                <p class="h5 mb-0 text-primary">@p.PricePerHour Kč<small class="text-muted">/hod</small></p>
                            </div>
                            <div class="text-end">
                                <h6 class="text-muted small text-uppercase fw-bold">Obsazenost</h6>
                                <span class="badge @(isFull ? "bg-danger" : "bg-success") rounded-pill">
                                    @p.SpzParkingPlaces.Count() / @p.Capacity
                                </span>
                            </div>
                        </div>
                    </div>

                    <div class="card-footer bg-transparent border-0 pb-3">
                        <div class="d-grid">
                            <a asp-controller="ParkingPlace" asp-action="BuySpot" asp-route-id="@p.Id"
                               class="btn @(isFull ? "btn-secondary disabled" : "btn-primary") btn-lg shadow-sm">
                                @(isFull ? "Obsazeno" : "Koupit místo")
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
